#!/bin/bash
# ==========================================
# BSCP : Foundation Architect - Launcher (made with ChatGPT)
# ==========================================

set -e

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$PROJECT_ROOT/venv"
PYTHON_BIN="$VENV_DIR/bin/python3"
REQUIREMENTS_FILE="$PROJECT_ROOT/requirement.txt"

GAME_ARGS=()

# ------------------------------------------------
# Virtual Environment Setup
# ------------------------------------------------
setup_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        echo "[INFO] Creating virtual environment..."
        python3 -m venv "$VENV_DIR"

        echo "[INFO] Installing packages..."
        "$PYTHON_BIN" -m pip install --upgrade pip

        if [ -f "$REQUIREMENTS_FILE" ]; then
            "$PYTHON_BIN" -m pip install -r "$REQUIREMENTS_FILE"
        fi
    fi
}

# ------------------------------------------------
# Update Packages
# ------------------------------------------------
update_packages() {
    echo "[INFO] Updating packages..."
    setup_venv

    "$PYTHON_BIN" -m pip install --upgrade pip

    if [ -f "$REQUIREMENTS_FILE" ]; then
        "$PYTHON_BIN" -m pip install --upgrade -r "$REQUIREMENTS_FILE"
    fi

    echo "[INFO] Update completed."
}

# ------------------------------------------------
# Reinstall Virtual Environment
# ------------------------------------------------
reinstall_venv() {
    echo "[INFO] Reinstalling virtual environment..."
    rm -rf "$VENV_DIR"
    setup_venv
}

# ------------------------------------------------
# Clean Temporary Files
# ------------------------------------------------
clean_temp() {
    echo "[INFO] Cleaning temporary files..."

    find "$PROJECT_ROOT" -type f -name "bscp_clean_*" -delete || true
    find "$PROJECT_ROOT" -type d -name "__pycache__" -exec rm -rf {} + || true

    echo "[INFO] Cleanup finished."
}

# ------------------------------------------------
# Check Environment
# ------------------------------------------------
check_environment() {
    echo "[INFO] Checking environment..."

    if ! command -v python3 &> /dev/null; then
        echo "[ERROR] python3 not found"
        exit 1
    fi

    echo -n "[INFO] Python version: "
    python3 --version

    if [ -d "$VENV_DIR" ]; then
        echo "[INFO] Virtual environment: OK"
    else
        echo "[WARN] Virtual environment missing"
    fi

    if [ -f "$REQUIREMENTS_FILE" ]; then
        echo "[INFO] Requirements file found"
    else
        echo "[WARN] requirement.txt missing"
    fi
}

# ------------------------------------------------
# Version
# ------------------------------------------------
show_version() {
    echo "BSCP : Foundation Architect"
    echo "Launcher version 1.0"
}

# ------------------------------------------------
# Help
# ------------------------------------------------
show_help() {
    echo "BSCP Launcher"
    echo ""
    echo "Launcher flags:"
    echo "  --update        Update Python dependencies"
    echo "  --reinstall     Recreate the virtual environment"
    echo "  --clean         Remove temporary files"
    echo "  --check         Check environment"
    echo "  --version       Show launcher version"
    echo "  --help          Show this help message"
    echo ""
    echo "Any other flags are forwarded to the game."
}

# ------------------------------------------------
# Argument Parsing
# ------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --update)
            update_packages
            exit 0
            ;;
        --reinstall)
            reinstall_venv
            exit 0
            ;;
        --clean)
            clean_temp
            exit 0
            ;;
        --check)
            check_environment
            exit 0
            ;;
        --version)
            show_version
            exit 0
            ;;
        --help)
            show_help
            exit 0
            ;;
        *)
            GAME_ARGS+=("$1")
            ;;
    esac
    shift
done

# ------------------------------------------------
# Launch Game
# ------------------------------------------------
setup_venv

exec "$PYTHON_BIN" "$PROJECT_ROOT/bscp.py" "${GAME_ARGS[@]}"