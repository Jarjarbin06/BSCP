#!/bin/bash
# ==========================================
# BSCP : Foundation Architect - Launcher
# ==========================================

# Exit on error
set -e

# Project root (adjust if the script is moved)
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"

# Virtual environment directory
VENV_DIR="$PROJECT_ROOT/venv"

# Python executable
PYTHON_BIN="$VENV_DIR/bin/python3"

# Function to create virtual environment if missing
setup_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        echo "[INFO] Creating virtual environment..."
        python3 -m venv "$VENV_DIR"
        echo "[INFO] Installing required packages..."
        "$PYTHON_BIN" -m pip install --upgrade pip
        if [ -f "$PROJECT_ROOT/requirement.txt" ]; then
            "$PYTHON_BIN" -m pip install -r "$PROJECT_ROOT/requirement.txt"
        fi
    fi
}

# Run the game
launch_game() {
    "$PYTHON_BIN" "$PROJECT_ROOT/bscp.py" "$@"
}

# Main
setup_venv
launch_game